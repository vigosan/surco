# Surco licensing — environment variables for the Vercel serverless functions in api/.
# Copy to .env (local) and set the same in the Vercel project settings.

# Neon Postgres connection string (Project → Connection Details → pooled connection).
# Run apps/web/db/schema.sql against it once before going live.
DATABASE_URL=postgres://user:pass@host/db?sslmode=require

# Stripe (use test keys until launch).
STRIPE_SECRET_KEY=sk_test_xxx
# Signing secret of the webhook endpoint you point at https://<site>/api/webhook
# (Stripe → Developers → Webhooks). Subscribe it to: checkout.session.completed,
# charge.refunded.
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Optional. Defaults: 29 and https://getsurco.app
PRO_PRICE_EUR=29
SITE_URL=https://getsurco.app

# Optional — license-delivery email via Resend. Without it, licenses are still shown on
# the /success page and stored in Neon, but not emailed (recovery needs this too).
RESEND_API_KEY=re_xxx
LICENSE_EMAIL_FROM=Surco <license@getsurco.app>

# Build-time flags for the static site (Vite). Keep the beta on (default) until launch;
# set to 0 to switch the pricing section to live Stripe checkout. The free monthly cap
# shown in the pricing copy mirrors the desktop's SURCO_FREE_MONTHLY (default 25).
# VITE_SURCO_BETA=0
# VITE_PRO_PRICE_EUR=29
# VITE_SURCO_FREE_MONTHLY=25
